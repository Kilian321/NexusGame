    {
      "name": "3. Créer un jeu",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// TODO — Vérifier status 201 et récupérer l'id pour le chaînage :",
              "",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201)",
              "})",
              "",
              "const id = pm.response.json().id;",
              "",
              "pm.collectionVariables.set('created_game_id', id);",
              "",
              "pm.test('ID présent', () => pm.expect(id).to.be.a('number'));",
              "",
              "",
              "",
              "",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"NexusGame Test {{$timestamp}}\",\n  \"genre\": \"RPG\",\n  \"price\": 49.99,\n  \"rating\": 4.5,\n  \"stock\": 100\n}"
        },
        "url": {
          "raw": "{{base_url}}/games",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "games"
          ]
        }
      },
      "response": []
    },
    {
      "name": "4. Récupérer le jeu créé",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const game = pm.response.json();",
              "",
              "pm.test(\"Game id matches created game id\", function () {",
              "    pm.expect(game.id).to.eql(Number(pm.collectionVariables.get(\"created_game_id\")));",
              "});",
              "",
              "",
              "pm.test(\"Game genre is RPG\", function () {",
              "    pm.expect(game.genre).to.eql(\"RPG\");",
              "});",
              "",
              "pm.test('Game title', () => {",
              "    const body = pm.response.json();",
              "    pm.expect(body[\"title\"]).to.includes(\"NexusGame Test\")",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
