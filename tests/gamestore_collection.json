    {
      "name": "2. Lister les jeux",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200)",
              "})",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    pm.expect(pm.response.json()).to.be.an('array')",
              "    })",
              "",
              "pm.test(\"Tableau non vide\", function () {",
              "    pm.expect(pm.response.json().length).to.be.at.least(1)",
              "    })",
              "",
              "pm.test(\"Chaque jeu a les champs : id, title, genre, price, rating\", function () {",
              "    const body = pm.response.json();",
              "    [\"id\",\"title\",\"genre\",\"price\",\"rating\"].forEach(key => {",
              "        pm.expect(body[0]).to.have.property(key)",
              "        })    ",
              "}) ",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
